# ── Supabase (required) ───────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── API backend ───────────────────────────────────────────────────────────────
# URL of the FastAPI backend — used server-side and at build time.
# In production set this to your deployed API URL.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# ── Sentry Error Tracking (optional — leave blank for local dev) ──────────────
# NEXT_PUBLIC_SENTRY_DSN=https://xxx@oyyy.ingest.sentry.io/zzz
# SENTRY_AUTH_TOKEN=   # needed for source map uploads during CI/CD builds
# SENTRY_ORG=your-org
# SENTRY_PROJECT=analyist-pro-web

# ── Anthropic (Claude AI) ─────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/analyist_pro

# ── Supabase ──────────────────────────────────────────────────────────────────
# Plain names used by the backend (preferred)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# Legacy HS256 secret — kept for verifying tokens issued before key rotation
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# NEXT_PUBLIC_ aliases — also accepted by the backend for compatibility
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Redis (optional — enables analysis result caching) ────────────────────────
# Leave unset to run without caching (results are still persisted in Postgres)
REDIS_URL=redis://localhost:6379

# ── S3 File Storage (optional — local disk fallback when unset) ───────────────
# Set S3_BUCKET to enable S3 storage; otherwise uploads are stored locally in
# the UPLOAD_DIR directory (default: ./uploads).
# S3_BUCKET=my-analyist-pro-uploads
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...

# ── Sentry Error Tracking (optional) ─────────────────────────────────────────
# SENTRY_DSN=https://xxx@oyyy.ingest.sentry.io/zzz
